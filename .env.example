# NextAuth
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=

# Microsoft Entra ID
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=

# Redis (Required for Rate Limiting and BullMQ)
REDIS_URL=redis://localhost:6379

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/lms?schema=public"

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Storage: GCS (primary) + MinIO (fallback) ────────────────────────────────
#
# GCS — leave GCP_BUCKET_NAME empty to skip GCS entirely (MinIO will be used).
# On GCP VMs, authentication uses Application Default Credentials automatically.
# Locally: run `gcloud auth application-default login` once to activate ADC.
GCP_BUCKET_NAME=

# MinIO — always available via Docker (see docker-compose.dev.yml).
# In dev: use localhost. In Docker Compose (staging/prod): use service name "minio".
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=lms_minio_dev
MINIO_SECRET_KEY=lms_minio_secret_dev
MINIO_BUCKET=lms-documents

# Gemini API Key (server-only — do NOT prefix with NEXT_PUBLIC)
GEMINI_API_KEY=

# ── PHI Scanner ──────────────────────────────────────────────────────────────
# Set to 'true' to block documents when PHI scanner fails (recommended for production)
PHI_FAIL_CLOSED=false

