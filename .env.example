# Database (Docker Compose Configuration)
POSTGRES_DB="lms"
POSTGRES_USER="lms"
POSTGRES_PASSWORD="secure_db_password"
# The 'db' host matches the docker-compose service name
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# Redis (For BullMQ Job Queues)
REDIS_PASSWORD="secure_redis_password"
# The 'redis' host matches the docker-compose service name
REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"

# Authentication
# Run 'openssl rand -base64 32' to generate a secret
AUTH_SECRET="supersecret"
# AUTH_URL: The canonical public URL of the app. Required by NextAuth v5 to validate
# sign-in/sign-out callbackUrls. Without this, sign-out redirects fall back to localhost.
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Microsoft Entra ID (Optional - for Admin OAuth)
AUTH_MICROSOFT_ENTRA_ID_ID="secret"
AUTH_MICROSOFT_ENTRA_ID_SECRET="secret"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="common"

# AI Services (Gemini / Vertex AI)
# For client-side usage (if any)
NEXT_PUBLIC_GEMINI_API_KEY="apikey"

# Email Configuration (SMTP / Zoho)
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASSWORD="password"

# Logging
# Levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL="debug"

#Figma
FIGMA_ACCESS_TOKEN="figma-access-token"
# Stripe (Billing)
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Create matching prices in Stripe dashboard for each plan/cycle
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_STARTER_QUARTERLY_PRICE_ID="price_..."
STRIPE_STARTER_YEARLY_PRICE_ID="price_..."
STRIPE_PROFESSIONAL_PRICE_ID="price_..."
STRIPE_PROFESSIONAL_QUARTERLY_PRICE_ID="price_..."
STRIPE_PROFESSIONAL_YEARLY_PRICE_ID="price_..."
# Enterprise sales inquiry recipient
ENTERPRISE_CONTACT_EMAIL="sales@test.com"
