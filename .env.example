# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── Authentication ──────────────────────────────────────────────────────────
# Generate secrets: openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=

# Microsoft Entra ID (Azure AD) OAuth
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=

# System admin default password
SYSTEM_ADMIN_PASSWORD=

# ── Inactivity Timeout ─────────────────────────────────────────────────────
# Number of minutes of inactivity before a user is automatically logged out.
# Default: 15 minutes. Minimum: 5, Maximum: 120.
INACTIVITY_TIMEOUT_MINUTES=15
NEXT_PUBLIC_INACTIVITY_TIMEOUT_MINUTES=15

# ── Database (Prisma / PostgreSQL) ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/lms?schema=public"

# ── Redis (Rate Limiting + BullMQ) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google Cloud / Vertex AI ────────────────────────────────────────────────
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us-central1

# Gemini API Key (server-only — do NOT prefix with NEXT_PUBLIC)
GEMINI_API_KEY=

# ── Storage: GCS (primary) + MinIO (fallback) ──────────────────────────────
GCP_BUCKET_NAME=

# MinIO — always available via Docker (see docker-compose.dev.yml).
# In dev: use localhost. In Docker Compose (staging/prod): use service name "minio".
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=lms_minio_dev
MINIO_SECRET_KEY=lms_minio_secret_dev
MINIO_BUCKET=lms-documents

# ── Stripe (Billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_QUARTERLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_PROFESSIONAL_QUARTERLY_PRICE_ID=
STRIPE_PROFESSIONAL_YEARLY_PRICE_ID=

# ── Email (SMTP / Zoho) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ZOHO_MAIL_USER=
ZOHO_MAIL_PASSWORD=

# ── PHI Scanner ────────────────────────────────────────────────────────────
# Set to 'true' to block documents when PHI scanner fails (recommended for production)
PHI_FAIL_CLOSED=false

# ── Enterprise ──────────────────────────────────────────────────────────────
ENTERPRISE_CONTACT_EMAIL=
