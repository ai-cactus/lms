# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── Authentication ──────────────────────────────────────────────────────────
# Generate secrets: openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=

# Microsoft Entra ID (Azure AD) OAuth
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=

# System admin default password
SYSTEM_ADMIN_PASSWORD=

# ── Inactivity Timeout ─────────────────────────────────────────────────────
# Number of minutes of inactivity before a user is automatically logged out.
# Default: 60 minutes. Minimum: 5, Maximum: 120.
INACTIVITY_TIMEOUT_MINUTES=60
NEXT_PUBLIC_INACTIVITY_TIMEOUT_MINUTES=60

# ── Database (Prisma / PostgreSQL) ──────────────────────────────────────────
# In production, DATABASE_URL MUST be a POOLED connection string (e.g. PgBouncer
# in transaction mode, or your provider's pooled endpoint). Append the pooler's
# own connection cap, e.g. ?pgbouncer=true&connection_limit=10, so the app never
# opens more server connections than the pooler allows.
# NOTE: Prisma migrations (migrate deploy/dev) must run against a DIRECT,
# UNPOOLED URL — PgBouncer's transaction pooling breaks DDL. That direct URL is
# configured in the Prisma schema's datasource (directUrl), not here.
DATABASE_URL="postgresql://user:password@localhost:5432/lms?schema=public"
# Max connections the app's pool may open (see db/index.ts). Keep it at or below
# your pooler/Postgres connection cap, divided across app instances. Default: 10.
DATABASE_POOL_MAX=10

# ── Redis (Rate Limiting + BullMQ) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Orphaned-video-object sweeper (BullMQ cron) ─────────────────────────────
# Reconciles the system/videos/ storage prefix against the database and deletes
# objects that nothing references. Set ENABLED=false to turn it off entirely.
VIDEO_SWEEP_ENABLED=true
# Objects newer than this are skipped (protects in-flight uploads + transcodes).
# MUST comfortably exceed worst-case transcode time — keep at 24h unless sure.
VIDEO_SWEEP_GRACE_PERIOD_HOURS=24
# Cron pattern for how often the sweep runs (default: every 6 hours).
VIDEO_SWEEP_CRON=0 */6 * * *
# When true, log what WOULD be deleted but delete nothing. Defaults to false.
# Run the FIRST real deploy with this set to true in staging to verify scope,
# then flip to false.
VIDEO_SWEEP_DRY_RUN=false

# ── Reminders & escalations sweeper (BullMQ cron) ───────────────────────────
# Runs the daily deadline reminder/escalation ladder + Track B (failing/locked
# quiz) nudges over active enrollments. Set ENABLED=false to turn it off entirely.
REMINDER_SWEEP_ENABLED=true
# Cron pattern for how often the sweep runs (default: daily at 08:00).
REMINDER_SWEEP_CRON=0 8 * * *
# When true, log intended sends and perform zero writes. Defaults to false.
REMINDER_SWEEP_DRY_RUN=false
# Days behind "today" a stage may still fire, covering a missed cron day.
REMINDER_CATCHUP_DAYS=2
# Minimum days between recurring Track B nudges of the same kind.
REMINDER_NUDGE_INTERVAL_DAYS=3

# ── Data retention / disposal purge (F-054) ─────────────────────────────────
# Runs at the start of the daily reminder sweep (skipped under dry-run). Deletes
# expired/stale rows on HIPAA-sensible windows. NOTE: audit logs are NEVER
# purged (retained >= 6 years). Set ENABLED=false to turn the purge off.
RETENTION_PURGE_ENABLED=true
# Days after a verification token's `expires` before it is purged (holds
# pending-signup data incl. hashed passwords — kept short).
RETENTION_VERIFICATION_TOKEN_GRACE_DAYS=1
# Age (days) at which terminal (accepted/expired) invites are purged.
RETENTION_INVITE_DAYS=30
# Age (days) at which terminal (completed/failed) jobs are purged.
RETENTION_JOB_DAYS=90
# Age (days) at which successfully-sent email delivery records are purged.
RETENTION_EMAIL_DAYS=90

# ── Google Cloud / Vertex AI ────────────────────────────────────────────────
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us-central1

# Gemini API Key (server-only — do NOT prefix with NEXT_PUBLIC)
GEMINI_API_KEY=

# v4.6 course generation wall-clock timeout (ms). Bounds the whole background
# pipeline so a stuck stage can't leave a job in `processing` forever.
# Server-side. Default: 600000 (10 min).
V46_GENERATION_TIMEOUT_MS=600000
# Client-side poll backstop (ms) for the generation UI. Keep slightly ABOVE
# V46_GENERATION_TIMEOUT_MS so the server normally settles the job first.
# Default: 660000 (11 min).
NEXT_PUBLIC_V46_GENERATION_TIMEOUT_MS=660000

# ── Storage: GCS (primary) + MinIO (fallback) ──────────────────────────────
GCP_BUCKET_NAME=
# Service-account key for GCS auth (staging and production only).
# On production/staging, the VM is not a GCP host so ADC cannot auto-resolve.
# Encode the downloaded JSON key:  base64 -w0 key.json
# Leave UNSET in local dev — use:  gcloud auth application-default login
GCS_KEY_BASE64=

# MinIO — always available via Docker (see docker-compose.dev.yml).
# In dev: use localhost. In Docker Compose (staging/prod): use service name "minio".
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=lms_minio_dev
MINIO_SECRET_KEY=lms_minio_secret_dev
MINIO_BUCKET=lms-documents

# ── Stripe (Billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_QUARTERLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_PROFESSIONAL_QUARTERLY_PRICE_ID=
STRIPE_PROFESSIONAL_YEARLY_PRICE_ID=

# ── Email (SMTP / Zoho) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ZOHO_MAIL_USER=
ZOHO_MAIL_PASSWORD=

# ── PHI Scanner ────────────────────────────────────────────────────────────
# DEPRECATED (THER-003): PHI detection is now always fail-closed — documents with
# detected PHI (or an unverifiable scan) are always blocked regardless of this var.
# Kept only to avoid breaking existing deploy configs; the code no longer reads it.
# PHI_FAIL_CLOSED=false

# ── Enterprise ──────────────────────────────────────────────────────────────
ENTERPRISE_CONTACT_EMAIL=

# ── Help Center ─────────────────────────────────────────────────────────────
# Support address surfaced as the mailto: link on the Help Center pages
# (/dashboard/help and /worker/help). Inlined into the browser bundle.
# Falls back to support@theraptly.com when unset.
NEXT_PUBLIC_SUPPORT_EMAIL=support@theraptly.com

# ── hCaptcha bot verification (F-023) ────────────────────────────────────────
# OPTIONAL. The feature is fully inert until enabled: leave these blank and no
# captcha widget renders and no server-side verification runs (public flows are
# unchanged). To turn it on, set HCAPTCHA_ENABLED=true AND provide the secret key,
# and set NEXT_PUBLIC_HCAPTCHA_ENABLED=true AND provide the public site key.
# Get keys at https://dashboard.hcaptcha.com/. Test keys are documented at
# https://docs.hcaptcha.com/#integration-testing-test-keys.
# Server-side (never exposed to the browser):
HCAPTCHA_ENABLED=
HCAPTCHA_SECRET_KEY=
# Client-side (inlined into the browser bundle):
NEXT_PUBLIC_HCAPTCHA_ENABLED=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
