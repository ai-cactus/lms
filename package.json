    "@react-pdf/renderer": "^4.5.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.33.0",
    "google-auth-library": "^10.6.2",
    "html-to-image": "^1.11.13",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^3.5.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.11.0",
    "minio": "^8.0.7",
    "next": "16.2.6",
    "nodemailer": "^9.0.1",
    "otpauth": "^9.5.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.22.0",
