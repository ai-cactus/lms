    "quill": "^2.0.3",
    "radix-ui": "^1.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-pdf": "^10.4.1",
    "react-quill-new": "^3.8.3",
