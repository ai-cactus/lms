generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                      String    @id @default(uuid())
  name                    String
  slug                    String    @unique
  dba                     String?
  ein                     String?
  staffCount              String?
  primaryContact          String?
  primaryEmail            String?
  phone                   String?
  address                 String?
  city                    String?
  country                 String?
  state                   String?
  zipCode                 String?
  licenseNumber           String?
  isHipaaCompliant        Boolean  @default(false)
  hasAuditorAccess        Boolean  @default(false)
  primaryBusinessType     String?
  additionalBusinessTypes String[]  @default([])
  programServices         String[]  @default([])
  joinCode                String?   @unique
  joinCodeExpiresAt       DateTime?
  stripeCustomerId        String?  @unique // Stripe customer ID
  users                   User[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  invites                 Invite[]
  subscription            Subscription?
  invoices                Invoice[]
}

model Invite {
  id             String       @id @default(uuid())
  email          String
  token          String       @unique
  organizationId String
  role           String       @default("worker")
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  invitedBy      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  organizationId String?
  role           String         @default("worker")
  emailVerified  Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  courses        Course[]
  documents      Document[]
  enrollments    Enrollment[]
  notifications  Notification[]
  profile        Profile?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
}

model Profile {
  id          String   @id
  email       String   @unique
  firstName   String?
  lastName    String?
  fullName    String?
  jobTitle    String?
  companyName String?
  avatarUrl             String?
  hasSeenAuditorWelcome Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user        User     @relation(fields: [id], references: [id], onDelete: Cascade)
}

model Document {
  id           String            @id @default(uuid())
  userId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id])
  versions     DocumentVersion[]
}

model DocumentVersion {
  id             String            @id @default(uuid())
  documentId     String
  version        Int               @default(1)
  storagePath    String
  hash           String
  content        String?
  createdAt      DateTime          @default(now())
  courseVersions CourseVersion[]
  document       Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  mapping        MappingEvidence[]
  phiReport      PhiReport?
}

model PhiReport {
  id                String          @id @default(uuid())
  documentVersionId String          @unique
  hasPHI            Boolean         @default(false)
  detectedEntities  Json?
  scannedAt         DateTime        @default(now())
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
}

model Course {
  id                 String          @id @default(uuid())
  title              String
  description        String?
  thumbnail          String?
  status             String          @default("draft")
  category           String?
  duration           Int?
  createdBy          String
  objectives         String[]        @default([])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  promptVersion      String?
  rawCourseJson      Json?
  rawQuizJson        Json?
  rawArticleMarkdown String?
  rawArticleMeta     Json?
  rawJudgeJson       Json?
  rawSlidesJson      Json?
  creator            User            @relation(fields: [createdBy], references: [id])
  versions           CourseVersion[]
  enrollments        Enrollment[]
  lessons            Lesson[]

  @@index([createdBy])
}

model CourseVersion {
  id                String          @id @default(uuid())
  courseId          String
  documentVersionId String
  version           Int
  publishedAt       DateTime        @default(now())
  course            Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id])
}

model MappingEvidence {
  id                String          @id @default(uuid())
  documentVersionId String
  standardId        String
  snippet           String
  justification     String?
  status            String          @default("pending")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id])
}

model AuditorPack {
  id          String   @id @default(uuid())
  generatedBy String
  scope       String
  downloadUrl String?
  generatedAt DateTime @default(now())
}

model Job {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  status    String   @default("queued")
  payload   Json?
  result    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  content   String
  order     Int
  duration  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz      Quiz?
}

model Quiz {
  id              String        @id @default(uuid())
  lessonId        String        @unique
  title           String
  passingScore    Int           @default(70)
  allowedAttempts Int?          @default(1)
  timeLimit       Int?
  difficulty      String?
  createdAt       DateTime      @default(now())
  questions       Question[]
  lesson          Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts        QuizAttempt[]
}

model Question {
  id            String  @id @default(uuid())
  quizId        String
  text          String
  type          String
  options       Json?
  correctAnswer String
  order         Int
  archetype     String?
  evidence      Json?
  explanation   String?
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id                   String        @id @default(uuid())
  userId               String
  courseId             String
  status               String        @default("enrolled")
  progress             Int           @default(0)
  score                Int?
  startedAt            DateTime      @default(now())
  completedAt          DateTime?
  attestedAt           DateTime?
  attestationSignature String?
  attestationRole      String?
  assignedByAdminId    String?
  lockedAt             DateTime?
  retakeOf             String?
  retakeReason         String?
  course               Course        @relation(fields: [courseId], references: [id])
  user                 User          @relation(fields: [userId], references: [id])
  quizAttempts         QuizAttempt[]

  @@index([userId, courseId])
  @@index([courseId])
}

model QuizAttempt {
  id           String     @id @default(uuid())
  enrollmentId String
  quizId       String
  answers      Json
  score        Int
  timeTaken    Int?
  attemptCount Int        @default(1)
  completedAt  DateTime   @default(now())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  quiz         Quiz       @relation(fields: [quizId], references: [id])

  @@unique([enrollmentId, quizId])
}

model VerificationToken {
  identifier String
  token      String
  type       String   @default("password_reset")
  expires    DateTime
  password   String?
  firstName  String?
  lastName   String?
  role       String?

  @@unique([identifier, token])
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  type       String
  title      String
  message    String
  isRead     Boolean   @default(false)
  linkUrl    String?
  metadata   Json?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id                   String       @id @default(uuid())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String       @unique
  stripePriceId        String
  plan                 String       // 'starter' | 'professional' | 'enterprise'
  billingCycle         String       // 'monthly' | 'quarterly' | 'yearly'
  status               String       // 'active' | 'past_due' | 'canceled' | 'trialing'
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model Invoice {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stripeInvoiceId String       @unique
  invoiceNumber   String       // e.g. "TH-8842"
  amountPaid      Int          // in cents
  currency        String       @default("usd")
  status          String       // 'paid' | 'open' | 'void' | 'uncollectible'
  invoiceUrl      String?      // Stripe-hosted invoice URL
  pdfUrl          String?      // Direct PDF download link
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime     @default(now())

  @@index([organizationId])
}