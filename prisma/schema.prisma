generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────
// Values use lowercase to match existing database data.
// A future migration can normalize to uppercase if desired.

enum UserRole {
  admin
  worker
}

enum JobStatus {
  queued
  processing
  completed
  failed
}

enum CourseStatus {
  draft
  published
}

enum EnrollmentStatus {
  enrolled
  assigned
  in_progress
  lessons_complete
  completed
  attested
  locked
  failed
  retry_requested
}

enum InviteStatus {
  pending
  accepted
  expired
}

enum SubscriptionPlan {
  starter
  professional
  enterprise
}

enum SubscriptionBillingCycle {
  monthly
  quarterly
  yearly
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

model Organization {
  id                      String    @id @default(uuid())
  name                    String
  slug                    String    @unique
  dba                     String?
  ein                     String?
  staffCount              String?
  primaryContact          String?
  primaryEmail            String?
  phone                   String?
  address                 String?
  city                    String?
  country                 String?
  state                   String?
  zipCode                 String?
  licenseNumber           String?
  isHipaaCompliant        Boolean  @default(false)
  hasAuditorAccess        Boolean  @default(false)
  primaryBusinessType     String?
  additionalBusinessTypes String[]  @default([])
  programServices         String[]  @default([])
  joinCode                String?   @unique
  joinCodeExpiresAt       DateTime?
  stripeCustomerId        String?  @unique // Stripe customer ID
  inactivityTimeoutMinutes Int     @default(15) // Minutes of inactivity before auto-logout (5–120)
  requireMfa              Boolean  @default(false) // Org-wide MFA enforcement
  users                   User[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  invites                 Invite[]
  subscription            Subscription?
  invoices                Invoice[]
}

model Invite {
  id             String       @id @default(uuid())
  email          String
  token          String       @unique
  organizationId String
  role           UserRole     @default(worker)
  status         InviteStatus @default(pending)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  invitedBy      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  passwordResetRequired Boolean @default(false)
  organizationId String?
  authProvider   String         @default("credentials")
  role           UserRole       @default(worker)
  emailVerified  Boolean        @default(false)
  mfaEnabled     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  courses        Course[]
  documents      Document[]
  enrollments    Enrollment[]
  notifications  Notification[]
  profile        Profile?
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  mfaFactors     MfaFactor[]
  mfaRecoveryCodes MfaRecoveryCode[]

  @@index([organizationId])
}

model Profile {
  id          String   @id
  email       String   @unique
  firstName   String?
  lastName    String?
  fullName    String?
  jobTitle    String?
  companyName String?
  avatarUrl             String?
  hasSeenAuditorWelcome Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user        User     @relation(fields: [id], references: [id], onDelete: Cascade)
}

model Document {
  id           String            @id @default(uuid())
  userId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions     DocumentVersion[]

  @@index([userId])
}

model DocumentVersion {
  id             String            @id @default(uuid())
  documentId     String
  version        Int               @default(1)
  storagePath    String
  hash           String
  content        String?
  createdAt      DateTime          @default(now())
  courseVersions CourseVersion[]
  document       Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  mapping        MappingEvidence[]
  phiReport      PhiReport?
}

model PhiReport {
  id                String          @id @default(uuid())
  documentVersionId String          @unique
  hasPHI            Boolean         @default(false)
  detectedEntities  Json?
  scannedAt         DateTime        @default(now())
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
}

model Course {
  id                 String          @id @default(uuid())
  title              String
  description        String?
  thumbnail          String?
  status             CourseStatus    @default(draft)
  category           String?
  duration           Int?
  createdBy          String
  objectives         String[]        @default([])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  promptVersion      String?
  rawCourseJson      Json?
  rawQuizJson        Json?
  rawArticleMarkdown String?
  rawArticleMeta     Json?
  rawJudgeJson       Json?
  rawSlidesJson      Json?
  creator            User            @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  versions           CourseVersion[]
  enrollments        Enrollment[]
  lessons            Lesson[]
  artifacts          CourseArtifact[]

  @@index([createdBy])
  @@index([status])
}

model CourseArtifact {
  id         String   @id @default(uuid())
  courseId   String
  type       String   // article_meta, article_markdown, slides, quiz, judge, course_json
  storageUri String   // gcs:// or minio:// URI
  mimeType   String   @default("application/json")
  sizeBytes  Int?
  version    Int      @default(1)
  createdAt  DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, type, version])
  @@index([courseId])
}

model CourseVersion {
  id                String          @id @default(uuid())
  courseId          String
  documentVersionId String
  version           Int
  publishedAt       DateTime        @default(now())
  course            Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id])
}

model MappingEvidence {
  id                String          @id @default(uuid())
  documentVersionId String
  standardId        String
  snippet           String
  justification     String?
  status            String          @default("pending")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
}

model AuditorPack {
  id          String   @id @default(uuid())
  generatedBy String
  scope       String
  downloadUrl String?
  generatedAt DateTime @default(now())
}

model Job {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  status    JobStatus @default(queued)
  payload   Json?
  result    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Lesson {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  content   String
  order     Int
  duration  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz      Quiz?
}

model Quiz {
  id              String        @id @default(uuid())
  lessonId        String        @unique
  title           String
  passingScore    Int           @default(70)
  allowedAttempts Int?          @default(1)
  timeLimit       Int?
  difficulty      String?
  createdAt       DateTime      @default(now())
  questions       Question[]
  lesson          Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts        QuizAttempt[]
}

model Question {
  id            String  @id @default(uuid())
  quizId        String
  text          String
  type          String
  options       Json?
  correctAnswer String
  order         Int
  archetype     String?
  evidence      Json?
  explanation   String?
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id                   String        @id @default(uuid())
  userId               String
  courseId             String
  status               EnrollmentStatus @default(enrolled)
  progress             Int           @default(0)
  score                Int?
  startedAt            DateTime      @default(now())
  completedAt          DateTime?
  attestedAt           DateTime?
  attestationSignature String?
  attestationRole      String?
  assignedByAdminId    String?
  lockedAt             DateTime?
  retakeOf             String?
  retakeReason         String?
  course               Course        @relation(fields: [courseId], references: [id])
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizAttempts         QuizAttempt[]

  // NOTE: @@index (not @@unique) on [userId, courseId] because the retake flow
  // (assignRetake) intentionally creates a second enrollment for the same
  // user-course pair when the original is locked. Application-level checks
  // (findFirst + skipDuplicates) prevent accidental duplicates.
  @@index([userId, courseId])
  @@index([courseId])
  @@index([completedAt])
}

model QuizAttempt {
  id           String     @id @default(uuid())
  enrollmentId String
  quizId       String
  answers      Json
  score        Int
  timeTaken    Int?
  attemptCount Int        @default(1)
  completedAt  DateTime   @default(now())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  quiz         Quiz       @relation(fields: [quizId], references: [id])

  @@unique([enrollmentId, quizId])
}

model VerificationToken {
  identifier String
  token      String
  type       String   @default("password_reset")
  expires    DateTime
  password   String?
  firstName  String?
  lastName   String?
  role       String?

  @@unique([identifier, token])
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  type       String
  title      String
  message    String
  isRead     Boolean   @default(false)
  linkUrl    String?
  metadata   Json?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id                   String       @id @default(uuid())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String       @unique
  stripePriceId        String
  plan                 SubscriptionPlan       // starter | professional | enterprise
  billingCycle         SubscriptionBillingCycle // monthly | quarterly | yearly
  status               SubscriptionStatus     // active | past_due | canceled | trialing
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model Invoice {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stripeInvoiceId String       @unique
  invoiceNumber   String       // e.g. "TH-8842"
  amountPaid      Int          // in cents
  currency        String       @default("usd")
  status          String       // 'paid' | 'open' | 'void' | 'uncollectible'
  invoiceUrl      String?      // Stripe-hosted invoice URL
  pdfUrl          String?      // Direct PDF download link
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime     @default(now())

  @@index([organizationId])
}

// ── MFA Models ────────────────────────────────────────────────────────────────

model MfaFactor {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("totp") // totp | backup
  secret    String?  // TOTP secret (encrypted at rest)
  name      String?  // e.g. "Google Authenticator"
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MfaRecoveryCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String    // bcrypt hash of recovery code
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}